# 由 nano_deploy/06_install_systemd.sh 生成 /etc/aero-halo-360/env。
# 本文件只展示字段，禁止提交真实用户名、SN、IP 或飞控设备 ID。
ROS_SETUP=/opt/ros/humble/setup.bash
AERO_WORKSPACE=/home/USER/AeroHalo360_ws
AERO_SOURCE=/home/USER/AeroHalo360_ws/src/aero-halo-360
LIVOX_WORKSPACE=/home/USER/ws_livox
LIVOX_LAUNCH_FILE=msg_MID360_launch.py
BASE_CONFIG=/home/USER/AeroHalo360_ws/install/aero_halo_360/share/aero_halo_360/config/default.yaml
PROFILE_CONFIG=/home/USER/AeroHalo360_ws/install/aero_halo_360/share/aero_halo_360/config/flight_low_speed.yaml
MAVLINK_CONNECTION=/dev/serial/by-id/REPLACE_WITH_STABLE_DEVICE
MAVLINK_BAUD=921600
LIDAR_PARENT_FRAME=base_link
LIDAR_CHILD_FRAME=livox_frame
LIDAR_X=0.0
LIDAR_Y=0.0
LIDAR_Z=0.0
LIDAR_ROLL=0.0
LIDAR_PITCH=0.0
LIDAR_YAW=0.0
